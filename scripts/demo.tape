# SharpInput Demo GIF Recording
# Usage: vhs scripts/demo.tape
# Output: assets/sharpinput-demo.gif

Output assets/sharpinput-demo.gif

Set FontSize 14
Set Width 1200
Set Height 600
Set Theme "Dracula"
Set Padding 24

Type@100 "echo '=== SharpInput v3.1 Demo ==='"
Enter
Sleep 1s

Type@100 "echo ''"
Enter
Type@100 "echo 'User input: 怎么学 RUP？'"
Enter
Sleep 500ms

Type@100 "echo ''"
Enter
Type@100 "echo '[SharpInput Level 0]'"
Enter
Type@100 "echo ''"
Enter
Type@100 "echo '诊断: 输入太短，缺少水平、目标、时间约束'"
Enter
Type@100 "echo ''"
Enter
Type@100 "echo '升级版:'"
Enter
Type@50 "echo '> 我是[当前水平]，想在[时间]内掌握 RUP。'"
Enter
Type@50 "echo '> 请给出分阶段学习路径：每阶段的概念、顺序、'"
Enter
Type@50 "echo '> 练习、常见错误和自检标准。'"
Enter
Type@50 "echo '> 不要只列资源清单，要说明为什么这样排序。'"
Enter
Sleep 1s

Type@100 "echo ''"
Enter
Type@100 "echo '---'"
Enter
Type@100 "echo ''"
Enter
Type@100 "echo 'User input: ChatGPT Plus 和 Claude Pro 选哪个？'"
Enter
Sleep 500ms

Type@100 "echo ''"
Enter
Type@100 "echo '[SharpInput Level 2 — Pressure Mode]'"
Enter
Type@100 "echo ''"
Enter
Type@100 "echo '诊断: 决策类问题，缺少使用场景、预算、优先级'"
Enter
Type@100 "echo ''"
Enter
Type@100 "echo '升级版:'"
Enter
Type@50 "echo '> 我主要用 AI 做[用途]，月预算[金额]。'"
Enter
Type@50 "echo '> 请直接推荐一个，不要说\"看需求\"。'"
Enter
Type@50 "echo '> 给出对比表（场景/弱项/成本/稳定性），'"
Enter
Type@50 "echo '> 并说明什么条件下应该切换。'"
Enter
Sleep 2s
